import { Server } from "@modelcontextprotocol/sdk/server/index.js";
import { StdioServerTransport } from "@modelcontextprotocol/sdk/server/stdio.js";
import { CallToolRequestSchema, ListToolsRequestSchema } from "@modelcontextprotocol/sdk/types.js";
import pkg from 'pg';
const { Pool } = pkg;
import fetch from 'node-fetch';

// 1. SETTING DATABASE (Ganti sesuai DB POS/ERP kamu)
const pool = new Pool({
  user: 'readonly',
  host: '172.16.114.122',
  database: 'staging-gdfash',
  password: 'h31C}PV7~OdL',
  port: 5758,
});

const server = new Server({
  name: "tuf-ai-analyst",
  version: "1.0.0",
}, {
  capabilities: { tools: {} },
});

// 2. DAFTAR TOOL UNTUK CHATBOX
server.setRequestHandler(ListToolsRequestSchema, async () => ({
  tools: [{
    name: "tanya_database",
    description: "Gunakan tool ini untuk bertanya apa saja tentang data penjualan atau stok.",
    inputSchema: {
      type: "object",
      properties: {
        pertanyaan: { type: "string", description: "Pertanyaan user dalam bahasa Indonesia" },
      },
      required: ["pertanyaan"],
    },
  }],
}));

// 3. LOGIKA: CHATBOX -> OLLAMA -> POSTGRES
server.setRequestHandler(CallToolRequestSchema, async (request) => {
  if (request.params.name === "tanya_database") {
    const { pertanyaan } = request.params.arguments;

    // A. Minta Llama 3.2 buatkan SQL
    const schema = "Tabel: sales(id, product_name, qty, price)."; 
    const aiResponse = await fetch('http://localhost:11434/api/generate', {
      method: 'POST',
      body: JSON.stringify({
        model: 'llama3.2',
        prompt: `Kamu pakar SQL. Schema: ${schema}. Buat SQL SELECT saja untuk: ${pertanyaan}. Jawab HANYA SQL mentah.`,
        stream: false
      })
    });

    const data = await aiResponse.json();
    const sql = data.response.trim();

    // B. Eksekusi ke Postgres
    try {
      const dbRes = await pool.query(sql);
      return {
        content: [{ type: "text", text: `SQL dijalankan: ${sql}\n\nHasil:\n${JSON.stringify(dbRes.rows, null, 2)}` }]
      };
    } catch (err) {
      return { content: [{ type: "text", text: `Gagal: ${err.message}\nSQL: ${sql}` }] };
    }
  }
});

const transport = new StdioServerTransport();
await server.connect(transport);